# BidsConnect — copy to .env and set as needed
# Optional: leave unset to use defaults (SQLite, console email, etc.)

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,bidsconnect.co.tz

# Database (optional; default is SQLite)
# DATABASE_URL=postgres://user:pass@localhost:5432/bidsconnect

# Static & media (optional)
# STATIC_ROOT=/var/www/bidsconnect/staticfiles
# MEDIA_ROOT=/var/www/bidsconnect/media

# Email — required for production (invitations, document expiry, tender notifications)
# Dev default: console backend + noreply@bidsconnect.co.tz
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@bidsconnect.co.tz

# For production SMTP, use for example:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=noreply@bidsconnect.co.tz
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# Links in emails (invitation accept URL, etc.)
SITE_URL=https://bidsconnect.co.tz

# Document expiry webhook: cron must send X-Webhook-Secret or Authorization: Bearer <this>
# If set, requests without the secret get 401. Leave empty to allow unauthenticated calls (dev only).
# DOCUMENT_EXPIRY_WEBHOOK_SECRET=
